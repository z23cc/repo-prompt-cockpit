{
  "name": "repoprompt-control-plane",
  "productName": "Repo Prompt Cockpit",
  "version": "0.1.2",
  "private": true,
  "license": "Apache-2.0",
  "description": "Native macOS cockpit companion for Repo Prompt workspaces and sessions.",
  "scripts": {
    "build": "swift build --package-path Native",
    "check": "swift run --package-path Native RepoPromptCockpitChecks",
    "dev": "swift run --package-path Native RepoPromptCockpitApp",
    "dev:live": "REPOPROMPT_COCKPIT_PROVIDER=live swift run --package-path Native RepoPromptCockpitApp",
    "package:preview": "node scripts/package-native-preview.mjs",
    "package:dmg": "node scripts/package-native-preview.mjs --dmg",
    "native:build": "swift build --package-path Native",
    "native:check": "swift run --package-path Native RepoPromptCockpitChecks",
    "native:package:preview": "node scripts/package-native-preview.mjs",
    "native:package:dmg": "node scripts/package-native-preview.mjs --dmg",
    "native:verify": "node scripts/check-release-hygiene.mjs && node scripts/package-native-preview.mjs --dmg",
    "verify": "node scripts/check-release-hygiene.mjs && swift build --package-path Native && swift run --package-path Native RepoPromptCockpitChecks"
  },
  "packageManager": "pnpm@8.15.0+sha512.ea45517d5285d123eac02c3793505fa1fd6da90a2fc60d1e8d9e0c1e9292886ecfaff513f062b9d1cc8021bb8615033b1ac5bea3b2ee3fc165a6d7034bbe6b03"
}
