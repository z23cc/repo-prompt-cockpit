{
  "name": "repoprompt-control-plane",
  "productName": "Repo Prompt Cockpit",
  "version": "0.1.2",
  "private": true,
  "license": "Apache-2.0",
  "description": "Desktop cockpit companion for Repo Prompt workspaces and sessions.",
  "main": "electron-main.cjs",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "pnpm build && electron .",
    "package:mac": "tsx scripts/package-macos-preview.ts",
    "package:mac:app": "tsx scripts/package-macos-preview.ts --skip-zip",
    "package:mac:dmg": "tsx scripts/package-macos-preview.ts --dmg",
    "lint": "eslint .",
    "test": "vitest run",
    "probe:rp": "tsx scripts/probe-rp-cli.ts",
    "smoke:menu": "tsx scripts/smoke-menu.ts",
    "smoke:dashboard": "tsx scripts/smoke-dashboard.ts",
    "smoke:missing-rp-cli": "RP_CLI_PATH=/definitely/missing/rp-cli tsx scripts/smoke-provider.ts missing-rp-cli",
    "smoke:socket-denied": "tsx scripts/smoke-provider.ts socket-denied",
    "smoke:binding-target": "tsx scripts/smoke-provider.ts binding-target",
    "smoke:tray": "pnpm build && RP_CONTROL_PLANE_DEMO=1 RP_CONTROL_PLANE_SMOKE=1 electron .",
    "verify": "pnpm lint && pnpm build && pnpm test && pnpm smoke:dashboard && pnpm smoke:menu && pnpm smoke:missing-rp-cli && pnpm smoke:socket-denied && pnpm smoke:binding-target && tsx scripts/check-release-hygiene.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "electron": "^39.2.6",
    "eslint": "^9.39.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.0.8"
  },
  "packageManager": "pnpm@8.15.0+sha512.ea45517d5285d123eac02c3793505fa1fd6da90a2fc60d1e8d9e0c1e9292886ecfaff513f062b9d1cc8021bb8615033b1ac5bea3b2ee3fc165a6d7034bbe6b03"
}
